# ============================================
# FRONTEND ENVIRONMENT VARIABLES
# These are used by the React app (client-side)
# ============================================

# Supabase Connection (REQUIRED)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here
VITE_SUPABASE_PROJECT_ID=your-project-id


# ============================================
# BACKEND SECRETS (Edge Functions)
# Set these in Supabase Dashboard → Settings → Edge Functions → Secrets
# Or in your hosting provider's environment variables
# ============================================

# Supabase (auto-provided in Supabase, manual if self-hosting)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key (⚠️ NEVER expose publicly)
# SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Admin Credentials (REQUIRED for create-admin edge function)
# ADMIN_EMAIL=your-admin-email@example.com
# ADMIN_PASSWORD=YourSecurePassword123!

# AI Gateway (choose one)
# Option 1: Lovable AI (only works on Lovable platform)
# LOVABLE_API_KEY=auto-generated-by-lovable
#
# Option 2: Google Gemini (for self-hosting)
# Single key:
# GEMINI_API_KEY=your-gemini-api-key
# Multiple keys (comma-separated, auto-failover on rate limits):
# GEMINI_API_KEYS=key1,key2,key3,key4,key5
# Get keys from https://aistudio.google.com/apikey
#
# Option 3: OpenAI (for self-hosting)
# OPENAI_API_KEY=sk-your-openai-key (get from https://platform.openai.com/api-keys)

# Firecrawl - Web scraping service (OPTIONAL but recommended)
# FIRECRAWL_API_KEY=fc-your-key (get from https://firecrawl.dev)

# ============================================
# ADMIN PANEL CONFIGURABLE (stored in database site_config table)
# These are NOT env variables - set them from Admin Panel UI at /bosspage-login
# ============================================
# payment_gateway = razorpay | stripe
# report_price = 29 (or any number)
# currency = INR
# razorpay_key_id = rzp_live_... (get from https://dashboard.razorpay.com)
# razorpay_key_secret = your-secret (get from Razorpay dashboard)
# stripe_key = sk_live_... (get from https://dashboard.stripe.com)
# whatsapp_number = 919876543210 (with country code, no +)

# ============================================
# RATE LIMITS (built-in, no configuration needed)
# ============================================
# analyze-reel: 20 requests/hour per IP
# seo-analyze: 15 requests/hour per IP
# create-payment: 10 requests/hour per IP
# generate-master-report: 5 requests/hour per IP
